---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Essays</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="actions">
			<button
				id="theme-toggle"
				type="button"
				class="icon-button"
				aria-label="Toggle color theme"
				title="Toggle color theme"
			>
				<svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
					<path
						fill="currentColor"
						d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
					></path>
				</svg>
				<svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
					<g fill="currentColor">
						<circle cx="12" cy="12" r="4"></circle>
						<path
							d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							fill="none"
						></path>
					</g>
				</svg>
			</button>
			<a href="https://github.com/danniewalden" target="_blank" rel="noopener" class="icon-button">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<script is:inline>
	(function () {
		var btn = document.getElementById('theme-toggle');
		if (!btn) return;
		btn.addEventListener('click', function () {
			var current = document.documentElement.getAttribute('data-theme');
			var next;
			if (current === 'dark') {
				next = 'light';
			} else if (current === 'light') {
				next = 'dark';
			} else {
				var dark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
				next = dark ? 'light' : 'dark';
			}
			document.documentElement.setAttribute('data-theme', next);
			try {
				localStorage.setItem('theme', next);
			} catch (e) {}
		});
	})();
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background-color: var(--bg-surface);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	.icon-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5em;
		background: transparent;
		border: none;
		color: rgb(var(--black));
		cursor: pointer;
		border-radius: 4px;
		text-decoration: none;
	}
	.icon-button:hover {
		color: var(--accent);
		background: rgba(var(--gray-light), 0.5);
	}
	/* Show moon in light mode, sun in dark mode */
	.sun-icon {
		display: none;
	}
	.moon-icon {
		display: block;
	}
	:root[data-theme='dark'] .moon-icon {
		display: none;
	}
	:root[data-theme='dark'] .sun-icon {
		display: block;
	}
	@media (prefers-color-scheme: dark) {
		:root:not([data-theme]) .moon-icon {
			display: none;
		}
		:root:not([data-theme]) .sun-icon {
			display: block;
		}
	}
</style>
