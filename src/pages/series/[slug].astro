---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const seriesNames = [...new Set(posts.map((p) => p.data.series).filter(Boolean))];
	return seriesNames.map((name) => ({
		params: { slug: name!.toLowerCase() },
		props: {
			series: name!,
			posts: posts
				.filter((p) => p.data.series === name)
				.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0)),
		},
	}));
}

const { series, posts } = Astro.props as {
	series: string;
	posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
};
const total = posts[0]?.data.seriesTotal ?? posts.length;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${series} — series`}
			description={`Essays in the ${series} series.`}
		/>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 1em;
			}
			h1 {
				margin: 0 0 0.25em 0;
			}
			.meta {
				color: rgb(var(--gray));
				margin: 0 0 2em 0;
			}
			ol {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			li {
				margin: 0 0 1.5em 0;
				padding: 1em 0;
				border-top: 1px solid rgb(var(--gray-light));
			}
			li:last-child {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.part {
				color: rgb(var(--gray));
				font-size: 0.85em;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
			.post-title {
				margin: 0.25em 0;
				font-size: 1.4em;
				line-height: 1.2;
			}
			.post-title a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.post-title a:hover {
				color: rgb(var(--accent));
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.description {
				margin: 0.5em 0 0 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>{series}</h1>
			<p class="meta">{posts.length} of {total} essay{total === 1 ? '' : 's'} in the series.</p>
			<ol>
				{
					posts.map((post) => (
						<li>
							<div class="part">
								Part {post.data.seriesPart} of {post.data.seriesTotal ?? total}
							</div>
							<h2 class="post-title">
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							</h2>
							<div class="date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<p class="description">{post.data.description}</p>
						</li>
					))
				}
			</ol>
		</main>
		<Footer />
	</body>
</html>
